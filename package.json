{
  "name": "@owine/unifi-network-mcp",
  "version": "2.3.1",
  "description": "MCP server for the UniFi Network API",
  "main": "dist/index.js",
  "bin": {
    "unifi-network-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
