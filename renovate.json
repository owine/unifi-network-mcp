{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "schedule": [
      "on monday"
    ],
    "automerge": true
  },
  "packageRules": [
    {
      "groupName": "eslint",
      "matchPackageNames": [
        "eslint",
        "@eslint/js",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "@vitest/*"
      ]
    },
    {
      "groupName": "types",
      "matchPackageNames": [
        "@types/*"
      ]
    },
    {
      "description": "Automerge dev tooling (non-compiler)",
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "matchPackageNames": [
        "!typescript"
      ]
    },
    {
      "description": "MCP SDK — always review",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge major bumps",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
