{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "semanticCommitType": "chore",
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "schedule": [
      "on monday"
    ],
    "automerge": true
  },
  "packageRules": [
    {
      "groupName": "eslint",
      "matchPackageNames": [
        "eslint",
        "@eslint/js",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "@vitest/*"
      ]
    },
    {
      "groupName": "types",
      "matchPackageNames": [
        "@types/*"
      ]
    },
    {
      "description": "Group non-major GHA digest/version bumps",
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest",
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "description": "Production deps use deps: prefix for release-please",
      "matchDepTypes": [
        "dependencies",
        "peerDependencies"
      ],
      "semanticCommitType": "deps",
      "semanticCommitScope": ""
    },
    {
      "description": "Group non-major production dependency patches",
      "groupName": "production-deps",
      "matchDepTypes": [
        "dependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchPackageNames": [
        "!@modelcontextprotocol/sdk"
      ]
    },
    {
      "description": "Automerge dev tooling (non-compiler)",
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "matchPackageNames": [
        "!typescript"
      ]
    },
    {
      "description": "Batch all non-major dev dependency bumps into one PR",
      "groupName": "dev-dependencies",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "MCP SDK — always review",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge major bumps",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ]
}
